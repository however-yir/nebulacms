# =========================
# NebulaCMS Runtime Config
# =========================

# Work directory
NEBULACMS_WORK_DIR=/root/.nebulacms

# Database (R2DBC)
NEBULACMS_DB_URL=r2dbc:pool:postgresql://127.0.0.1:5432/nebulacms
NEBULACMS_DB_USERNAME=postgres
NEBULACMS_DB_PASSWORD=postgres

# Redis (optional)
NEBULACMS_REDIS_HOST=127.0.0.1
NEBULACMS_REDIS_PORT=6379
NEBULACMS_REDIS_USERNAME=
NEBULACMS_REDIS_PASSWORD=
NEBULACMS_REDIS_DATABASE=0
NEBULACMS_REDIS_SSL=false

# Ollama (optional)
NEBULACMS_OLLAMA_ENABLED=false
NEBULACMS_OLLAMA_BASE_URL=http://127.0.0.1:11434
NEBULACMS_OLLAMA_MODEL=llama3.1
NEBULACMS_OLLAMA_TIMEOUT=30s

# Container image publishing
GHCR_USERNAME=
GHCR_TOKEN=
DOCKER_USERNAME=
DOCKER_TOKEN=
